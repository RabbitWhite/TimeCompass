{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noCheck": true,
    "noResolve": true,
    "isolatedModules": true
  },
  "include": ["src"],
  "exclude": ["src/vite-env.d.ts"]
}
